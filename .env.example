# Supabase (create a project at https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose to the browser). Optional for Phase 1 UI-only flows.
# SUPABASE_SERVICE_ROLE_KEY=

# Used for email confirmation redirects in auth flows (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostHog — optional; app runs without it. Get a project key from PostHog; use EU host if your project is EU.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# Default US cloud API (omit or override for EU / self-host), no trailing slash:
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
